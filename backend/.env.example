# UPJ CRM Marketing WhatsApp Backend
# Environment Configuration Template
# 
# INSTRUCTIONS:
# 1. Copy this file to .env in the same directory
# 2. Update values with your actual configuration
# 3. NEVER commit .env to version control
# 4. Keep .env.example in git (without sensitive values)

# ============================================================
# SERVER CONFIGURATION
# ============================================================
NODE_ENV=development
PORT=5000
HOST=127.0.0.1
TIMEZONE=Asia/Jakarta

# ============================================================
# DATABASE CONFIGURATION
# PostgreSQL Connection
# ============================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=crm_marketing_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here
# 
# Alternative: Use DATABASE_URL instead (takes precedence over individual vars)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/crm_marketing_db

# ============================================================
# REDIS CONFIGURATION
# For BullMQ message queue
# ============================================================
REDIS_URL=redis://127.0.0.1:6379
# Format options:
# - redis://127.0.0.1:6379 (local, default)
# - redis://username:password@hostname:port/db (with auth)
# - rediss://hostname:port (TLS/SSL)
# 
# Example with password:
# REDIS_URL=redis://:your_password@redis.example.com:6379/0

# ============================================================
# AUTHENTICATION
# JWT Secret for token signing
# ============================================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRY=7d
# 
# Security: Use a strong random string (min 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ============================================================
# WhatsApp CLOUD API CONFIGURATION
# Get credentials from Meta Business Manager
# ============================================================

# Webhook Verification Token (you create this)
# Used for Meta to verify webhook endpoint
# Generate a random string or use: cat /dev/urandom | tr -dc 'A-Za-z0-9' | head -c 32
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_change_this

# Meta API Access Token
# Get from: https://developers.facebook.com/apps/[app-id]/settings/basic
# Format: EAAJvP... (long token starting with EAA)
# KEEP THIS SECRET! Use strong secret management in production
WHATSAPP_ACCESS_TOKEN=EAAJvP1234567890abcdefghijklmnopqrstuvwxyz

# WhatsApp Phone Number ID
# Get from: https://business.facebook.com/wa/manage/phone-numbers/
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# White Business Account ID (optional, for advanced features)
# Get from: https://business.facebook.com/settings/info
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# API Base URL (usually doesn't change)
WHATSAPP_API_URL=https://graph.instagram.com/v18.0

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
FRONTEND_URL=http://localhost:5173
# Production: https://yourdomain.com

# ============================================================
# MESSAGE QUEUE CONFIGURATION
# BullMQ Job Queue Settings
# ============================================================

# Max number of jobs to process concurrently
QUEUE_MAX_CONCURRENCY=5

# Job timeout (milliseconds)
QUEUE_JOB_TIMEOUT=10000

# Exponential backoff base delay (milliseconds)
QUEUE_BACKOFF_DELAY=2000

# Max retry attempts
QUEUE_MAX_RETRIES=3

# ============================================================
# RATE LIMITING
# WhatsApp Message Sending Rate
# ============================================================

# Default messages per second (can be overridden per blast)
RATE_PER_SECOND=10

# Messages per minute cap (safety limit)
RATE_LIMIT_PER_MINUTE=600

# ============================================================
# LOGGING
# ============================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json or text
LOG_FORMAT=text

# ============================================================
# MONITORING & HEALTH CHECK
# ============================================================

# Health check interval (milliseconds)
HEALTH_CHECK_INTERVAL=30000

# Metrics collection enabled
METRICS_ENABLED=false

# ============================================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ============================================================

# Google Cloud Storage (for CSV upload storage)
# GCS_PROJECT_ID=your-project-id
# GCS_BUCKET_NAME=uploads-bucket
# GCS_KEY_FILE=/path/to/service-account-key.json

# SendGrid (for email notifications)
# SENDGRID_API_KEY=SG.xxx

# Sentry (for error tracking)
# SENTRY_DSN=https://xxx@sentry.io/123

# ============================================================
# DEVELOPMENT ONLY
# ============================================================

# Enable CORS for frontend development
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173

# SQL Query Logging (development only)
SQL_DEBUG=false

# Disable auth middleware (DEV ONLY - NEVER use in production!)
# DEBUG_SKIP_AUTH=false

# ============================================================
# TIPS FOR PRODUCTION
# ============================================================
# 
# 1. SECURITY:
#    - Use strong, random values for all secrets
#    - Rotate JWT_SECRET regularly
#    - Use environment variable management service (AWS Secrets Manager, HashiCorp Vault, etc)
#    - Enable TLS for Redis connection (rediss://)
#    - Use connection pooling for database
#
# 2. DATABASE:
#    - Use managed database service (AWS RDS, Google Cloud SQL, etc)
#    - Enable automated backups
#    - Use read replicas for read-heavy workloads
#
# 3. REDIS:
#    - Use managed Redis service (AWS ElastiCache, Google Memorystore, etc)
#    - Enable persistence (RDB or AOF)
#    - Set up replication and failover
#
# 4. API CREDENTIALS:
#    - Store Meta credentials in secrets manager
#    - Rotate access tokens regularly
#    - Use different tokens for dev/staging/production
#    - Monitor token usage and set up alerts
#
# 5. MONITORING:
#    - Set up application monitoring (New Relic, DataDog, Sentry, etc)
#    - Monitor queue depth and job processing time
#    - Set up alerts for failures
#
# ============================================================
