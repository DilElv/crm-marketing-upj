# UPJ CRM Marketing Backend - Development Environment
# Copy from .env.example and customize for your environment
# This is for LOCAL DEVELOPMENT only

# ============================================================
# SERVER
# ============================================================
NODE_ENV=development
PORT=5000
HOST=127.0.0.1
TIMEZONE=Asia/Jakarta

# ============================================================
# DATABASE
# ============================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=crm_marketing_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://127.0.0.1:6379

# ============================================================
# AUTHENTICATION
# ============================================================
JWT_SECRET=dev_secret_key_change_in_production_12345678901234567890
JWT_EXPIRY=7d

# ============================================================
# WhatsApp API
# TODO: Replace with actual Meta credentials when you get them
# ============================================================
WHATSAPP_WEBHOOK_VERIFY_TOKEN=test_webhook_token_dev_123456789
WHATSAPP_ACCESS_TOKEN=EAA_dev_placeholder_replace_with_real_token
WHATSAPP_PHONE_NUMBER_ID=1234567890123
WHATSAPP_API_URL=https://graph.instagram.com/v18.0

# ============================================================
# FRONTEND
# ============================================================
FRONTEND_URL=http://localhost:5173

# ============================================================
# MESSAGE QUEUE
# ============================================================
QUEUE_MAX_CONCURRENCY=5
QUEUE_JOB_TIMEOUT=10000
QUEUE_BACKOFF_DELAY=2000
QUEUE_MAX_RETRIES=3

# ============================================================
# RATE LIMITING
# ============================================================
RATE_PER_SECOND=10
RATE_LIMIT_PER_MINUTE=600

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=text

# ============================================================
# DEVELOPMENT
# ============================================================
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173
SQL_DEBUG=false
