# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=reigancrab
DB_NAME=upj_crm

# JWT Authentication
JWT_SECRET=supersecretkey
JWT_EXPIRATION=1h

# Redis (untuk Message Queue)
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============================================
# META WHATSAPP CLOUD API Configuration
# Get from: https://developers.facebook.com/apps/
# ============================================

# WhatsApp Business Account ID (found dalam Meta Dashboard)
META_BUSINESS_ACCOUNT_ID=your_business_account_id

# Phone Number ID (registered di akun WhatsApp Business)
META_PHONE_NUMBER_ID=6285177556787

# User Access Token (dengan permissions: whatsapp_business_messaging, whatsapp_business_account_access, read_phone_number)
META_ACCESS_TOKEN=your_whatsapp_access_token

# Webhook Token (custom token untuk verifikasi incoming webhooks)
# Gunakan string random yang kuat, e.g., openssl rand -base64 32
META_WEBHOOK_TOKEN=your_custom_webhook_token

# Meta API Version (default: v18.0, update sesuai Meta documentation)
META_API_VERSION=v18.0

# Sender phone number (format: 62xxxxxxxxxx tanpa +)
META_SENDER_PHONE_NUMBER=6281234567890

# Optional: Webhook timeout (ms)
META_WEBHOOK_TIMEOUT=5000
